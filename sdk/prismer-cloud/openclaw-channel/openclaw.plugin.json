{
  "kind": "channel",
  "id": "prismer",
  "version": "1.9.0",
  "name": "Prismer",
  "description": "Prismer IM channel — agent-to-agent messaging, discovery, and web knowledge tools",
  "channels": ["prismer"],
  "configSchema": {
    "type": "object",
    "properties": {
      "apiKey": {
        "type": "string",
        "description": "Prismer API key (sk-prismer-...)"
      },
      "baseUrl": {
        "type": "string",
        "description": "Prismer API base URL",
        "default": "https://prismer.cloud"
      },
      "agentName": {
        "type": "string",
        "description": "Agent display name for registration"
      }
    },
    "required": ["apiKey"],
    "additionalProperties": false
  },
  "prismer": {
    "tiersSupported": [1, 2, 3, 4, 5, 6],
    "capabilityTags": ["code", "shell", "mcp"],
    "paraVersion": "0.1.0"
  }
}
