{
  "name": "prismer-cloud-next",
  "version": "1.7.2",
  "private": true,
  "scripts": {
    "dev": "npx tsx server.ts",
    "dev:next": "next dev",
    "build": "next build",
    "start": "node custom-server.js",
    "start:next": "next start",
    "lint": "eslint",
    "im:start": "npx tsx src/im/start.ts",
    "im:dev": "npx tsx watch src/im/start.ts",
    "prisma:generate": "npx prisma generate",
    "prisma:generate:mysql": "npx prisma generate --schema=prisma/schema.mysql.prisma",
    "prisma:generate:all": "npx prisma generate && npx prisma generate --schema=prisma/schema.mysql.prisma",
    "prisma:push": "npx prisma db push",
    "prisma:studio": "npx prisma studio",
    "test:all": "npx tsx scripts/test-all-apis.ts",
    "test:all:local": "TEST_ENV=local npx tsx scripts/test-all-apis.ts",
    "test:all:test": "TEST_ENV=test npx tsx scripts/test-all-apis.ts",
    "test:all:prod": "TEST_ENV=prod npx tsx scripts/test-all-apis.ts",
    "test:e2e": "npx tsx scripts/e2e-self-host.ts",
    "test:e2e:no-docker": "npx tsx scripts/e2e-self-host.ts --no-docker",
    "format": "prettier --write \"src/**/*.{ts,tsx}\"",
    "check": "eslint && tsc --noEmit",
    "circular": "madge --circular --extensions ts,tsx src/",
    "prepare": "husky"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.990.0",
    "@aws-sdk/s3-presigned-post": "^3.990.0",
    "@aws-sdk/s3-request-presigner": "^3.990.0",
    "@hono/node-server": "^1.19.9",
    "@noble/curves": "^2.0.1",
    "@noble/hashes": "^2.0.1",
    "@paper-design/shaders-react": "^0.0.68",
    "@prisma/client": "^6.19.2",
    "@react-three/fiber": "^9.4.2",
    "@stripe/react-stripe-js": "^5.4.1",
    "@stripe/stripe-js": "^8.6.3",
    "@types/d3-force": "^3.0.10",
    "avvvatars-react": "^0.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "d3-force": "^3.0.0",
    "exa-js": "^2.0.11",
    "file-type": "^16.5.4",
    "hono": "^4.11.8",
    "html2pdf.js": "^0.12.1",
    "ioredis": "^5.9.2",
    "jsonwebtoken": "^9.0.3",
    "katex": "^0.16.27",
    "lucide-react": "^0.561.0",
    "mysql2": "^3.16.1",
    "next": "16.0.10",
    "nodemailer": "^8.0.4",
    "openai": "^6.13.0",
    "phaser": "^3.80.1",
    "prisma": "^6.19.2",
    "proxy-agent": "^5.0.0",
    "radix-ui": "^1.4.3",
    "react": "19.2.1",
    "react-dom": "19.2.1",
    "react-katex": "^3.1.0",
    "recharts": "^3.6.0",
    "shiki": "^3.22.0",
    "stripe": "^20.2.0",
    "tailwind-merge": "^3.4.0",
    "three": "^0.182.0",
    "ws": "^8.19.0",
    "yaml": "^2.8.2"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --no-warn-ignored",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml,css}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^20.19.37",
    "@types/nodemailer": "^7.0.11",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/ws": "^8.18.1",
    "babel-plugin-react-compiler": "1.0.0",
    "eslint": "^9",
    "eslint-config-next": "16.0.10",
    "eslint-plugin-boundaries": "^6.0.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "madge": "^8.0.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4",
    "tsup": "^8.5.1",
    "tsx": "^4.21.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "5.9.3"
  }
}
