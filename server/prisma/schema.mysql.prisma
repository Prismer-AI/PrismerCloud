// ==============================================================================
// Prismer Cloud - IM Server MySQL Schema
// ==============================================================================
//
// MySQL variant of schema.prisma for test/production environments.
// Matches tables created by src/im/sql/001-012 migrations.
//
// IMPORTANT:
// - Do NOT use `prisma db push` with this schema (tables managed by SQL migrations)
// - Generate client: npx prisma generate --schema=prisma/schema.mysql.prisma
// - im_credits / im_credit_transactions are EXCLUDED (dev-only, prod uses pc_* tables)
//
// ==============================================================================

generator client {
  provider = "prisma-client-js"
  output   = "./generated/mysql"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

// ==============================================================================
// IM 用户
// ==============================================================================

model IMUser {
  id            String    @id @default(cuid()) @db.VarChar(30)
  username      String    @unique @db.VarChar(100)
  displayName   String    @db.VarChar(200)
  passwordHash  String?   @db.VarChar(255)
  role          String    @default("human") @db.VarChar(20)
  agentType     String?   @db.VarChar(30)
  avatarUrl     String?   @db.VarChar(500)
  metadata      String?   @db.Text
  userId        String?   @db.VarChar(50)
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  updatedAt     DateTime  @updatedAt @db.DateTime(3)

  // Security (v1.7.2)
  trustTier       Int       @default(0)
  violationCount  Int       @default(0)
  suspendedUntil  DateTime? @db.DateTime(3)
  lastViolationAt DateTime? @db.DateTime(3)
  // Moderation (v1.7.3)
  reportBanUntil  DateTime? @db.DateTime(3)
  quarantineCount Int       @default(0)
  publishCount    Int       @default(0)
  banned          Boolean   @default(false)
  bannedAt        DateTime? @db.DateTime(3)
  banReason       String?   @db.VarChar(500)
  // AIP Layer 1: DID identity
  primaryDid      String?   @unique @db.VarChar(128)
  delegatedBy     String?   @db.VarChar(128)

  // Contact system (v1.8.0 P9)
  institution     String?   @db.VarChar(200)
  description     String?   @db.VarChar(500)
  lastSeenAt      DateTime? @db.DateTime(3)

  agentCard     IMAgentCard?
  identityKey   IMIdentityKey?
  participations IMParticipant[]
  sentMessages  IMMessage[]
  createdConversations IMConversation[]
  readCursors   IMReadCursor[]
  bindings      IMBinding[]
  fileUploads   IMFileUpload[]

  // Contact system relations (v1.8.0 P9)
  friendRequestsSent     IMFriendRequest[]   @relation("FriendRequestsSent")
  friendRequestsReceived IMFriendRequest[]   @relation("FriendRequestsReceived")
  contactsOwned          IMContactRelation[] @relation("ContactsOwned")
  contactsOf             IMContactRelation[] @relation("ContactsOf")
  blocksOwned            IMBlock[]           @relation("BlocksOwned")
  blockedBy              IMBlock[]           @relation("BlockedBy")

  @@index([role])
  @@index([userId])
  @@index([primaryDid])
  @@map("im_users")
}

// ==============================================================================
// Agent 名片 (能力声明)
// ==============================================================================

model IMAgentCard {
  id              String    @id @default(cuid()) @db.VarChar(30)
  imUserId        String    @unique @db.VarChar(30)
  name            String    @db.VarChar(200)
  description     String    @default("") @db.Text
  agentType       String    @default("assistant") @db.VarChar(30)
  capabilities    String    @default("[]") @db.Text
  protocolVersion String    @default("1.0") @db.VarChar(20)
  endpoint        String?   @db.VarChar(500)
  metadata        String    @default("{}") @db.Text
  lastHeartbeat   DateTime? @db.DateTime(3)
  status          String    @default("offline") @db.VarChar(20)
  load            Float     @default(0) @db.Double
  createdAt       DateTime  @default(now()) @db.DateTime(3)
  updatedAt       DateTime  @updatedAt @db.DateTime(3)

  // AIP Layer 2: DID Document
  did             String?   @db.VarChar(128)
  didDocumentUrl  String?   @db.VarChar(512)

  imUser          IMUser    @relation(fields: [imUserId], references: [id], onDelete: Cascade)

  @@index([status])
  @@map("im_agent_cards")
}

// ==============================================================================
// AIP Layer 3-4: Agent Credentials, DID Mappings, Revocation
// ==============================================================================

model IMAgentCredential {
  id              String    @id @default(cuid()) @db.VarChar(30)
  holderDid       String    @db.VarChar(128)
  credentialType  String    @db.VarChar(50)
  issuerDid       String    @db.VarChar(128)
  credential      String    @db.MediumText
  validFrom       DateTime  @db.DateTime(3)
  validUntil      DateTime? @db.DateTime(3)
  revoked         Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.DateTime(3)

  @@index([holderDid])
  @@index([issuerDid])
  @@index([credentialType])
  @@map("im_agent_credentials")
}

model IMDIDMapping {
  id              String    @id @default(cuid()) @db.VarChar(30)
  did             String    @unique @db.VarChar(128)
  imUserId        String    @db.VarChar(30)
  didMethod       String    @db.VarChar(10)
  isPrimary       Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.DateTime(3)

  @@index([imUserId])
  @@map("im_did_mappings")
}

model IMRevocationEntry {
  id              String    @id @default(cuid()) @db.VarChar(30)
  issuerDid       String    @db.VarChar(128)
  targetDid       String    @db.VarChar(128)
  credentialId    String?   @db.VarChar(128)
  reason          String    @db.VarChar(500)
  statusListIndex Int
  createdAt       DateTime  @default(now()) @db.DateTime(3)

  @@unique([issuerDid, targetDid, credentialId])
  @@index([targetDid])
  @@map("im_revocation_entries")
}

// ==============================================================================
// 对话
// ==============================================================================

model IMConversation {
  id            String    @id @default(cuid()) @db.VarChar(30)
  type          String    @default("direct") @db.VarChar(20)
  title         String?   @db.VarChar(255)
  description   String?   @db.Text
  status        String    @default("active") @db.VarChar(20)
  metadata      String    @default("{}") @db.Text
  createdById   String    @db.VarChar(30)
  workspaceId   String?   @unique @db.VarChar(50)
  lastMessageAt DateTime? @db.DateTime(3)
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  updatedAt     DateTime  @updatedAt @db.DateTime(3)

  createdBy     IMUser    @relation(fields: [createdById], references: [id])
  participants  IMParticipant[]
  messages      IMMessage[]
  readCursors   IMReadCursor[]

  @@index([status])
  @@index([createdById])
  @@index([lastMessageAt])
  @@map("im_conversations")
}

// ==============================================================================
// 参与者
// ==============================================================================

model IMParticipant {
  id              String    @id @default(cuid()) @db.VarChar(30)
  conversationId  String    @db.VarChar(30)
  imUserId        String    @db.VarChar(30)
  role            String    @default("member") @db.VarChar(20)
  joinedAt        DateTime  @default(now()) @db.DateTime(3)
  leftAt          DateTime? @db.DateTime(3)
  pinned          Boolean   @default(false)
  muted           Boolean   @default(false)
  pinnedAt        DateTime? @db.DateTime(3)

  conversation    IMConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  imUser          IMUser    @relation(fields: [imUserId], references: [id], onDelete: Cascade)

  @@unique([conversationId, imUserId])
  @@index([imUserId])
  @@map("im_participants")
}

// ==============================================================================
// 消息
// ==============================================================================

model IMMessage {
  id              String    @id @default(cuid()) @db.VarChar(30)
  conversationId  String    @db.VarChar(30)
  senderId        String    @db.VarChar(30)
  type            String    @default("text") @db.VarChar(30)
  content         String    @default("") @db.LongText
  metadata        String    @default("{}") @db.Text
  parentId        String?   @db.VarChar(30)
  quotedMessageId String?   @db.VarChar(30)
  status          String    @default("sent") @db.VarChar(20)
  createdAt       DateTime  @default(now()) @db.DateTime(3)
  updatedAt       DateTime  @updatedAt @db.DateTime(3)

  // E2E Encryption Layer 2: Signing & Integrity (v1.7.2)
  secVersion      Int?
  senderKeyId     String?   @db.VarChar(16)
  sequence        Int?
  contentHash     String?   @db.VarChar(64)
  prevHash        String?   @db.VarChar(64)
  signature       String?   @db.Text

  // AIP Layer 2: DID-based signing
  senderDid       String?   @db.VarChar(128)
  delegationProof String?   @db.MediumText

  // E2E Layer 5: encryption first-class field (S5 fix)
  encrypted       Boolean   @default(false)

  conversation    IMConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  sender          IMUser    @relation(fields: [senderId], references: [id])
  reactions       IMMessageReaction[]

  @@index([conversationId])
  @@index([senderId])
  @@index([createdAt])
  @@index([parentId])
  @@index([quotedMessageId])
  @@index([senderDid])
  @@index([conversationId, senderId, sequence])
  @@map("im_messages")
}

// ==============================================================================
// 消息反应 (Reactions, v1.8.2)
// ==============================================================================

model IMMessageReaction {
  id        String   @id @default(cuid()) @db.VarChar(30)
  messageId String   @db.VarChar(30)
  userId    String   @db.VarChar(36)
  emoji     String   @db.VarChar(32)
  createdAt DateTime @default(now()) @db.DateTime(3)

  message   IMMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([messageId, userId, emoji])
  @@index([messageId])
  @@index([userId])
  @@map("im_message_reactions")
}

// ==============================================================================
// 已读位置追踪
// ==============================================================================

model IMReadCursor {
  id              String    @id @default(cuid()) @db.VarChar(30)
  conversationId  String    @db.VarChar(30)
  imUserId        String    @db.VarChar(30)
  lastReadAt      DateTime  @default(now()) @db.DateTime(3)
  lastReadMsgId   String?   @db.VarChar(30)
  createdAt       DateTime  @default(now()) @db.DateTime(3)
  updatedAt       DateTime  @updatedAt @db.DateTime(3)

  conversation    IMConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  imUser          IMUser    @relation(fields: [imUserId], references: [id], onDelete: Cascade)

  @@unique([conversationId, imUserId])
  @@index([imUserId])
  @@map("im_read_cursors")
}

// ==============================================================================
// Webhook 配置
// ==============================================================================

model IMWebhook {
  id            String    @id @default(cuid()) @db.VarChar(30)
  url           String    @db.VarChar(500)
  events        String    @default("[]") @db.Text
  secret        String?   @db.VarChar(100)
  active        Boolean   @default(true)
  createdById   String    @db.VarChar(30)
  failureCount  Int       @default(0)
  lastTriggered DateTime? @db.DateTime(3)
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  updatedAt     DateTime  @updatedAt @db.DateTime(3)

  @@index([active])
  @@map("im_webhooks")
}

// ==============================================================================
// v0.3.0 — 社交平台绑定
// ==============================================================================

model IMBinding {
  id              String    @id @default(cuid()) @db.VarChar(30)
  imUserId        String    @db.VarChar(30)
  platform        String    @db.VarChar(30)
  status          String    @default("pending") @db.VarChar(20)

  externalId      String?   @db.VarChar(200)
  externalName    String?   @db.VarChar(200)

  botToken        String?   @db.VarChar(500)
  webhookUrl      String?   @db.VarChar(500)
  channelId       String?   @db.VarChar(100)

  verificationCode String?  @db.VarChar(10)
  verifiedAt      DateTime? @db.DateTime(3)

  capabilities    String    @default("[]") @db.Text
  config          String    @default("{}") @db.Text

  createdAt       DateTime  @default(now()) @db.DateTime(3)
  updatedAt       DateTime  @updatedAt @db.DateTime(3)

  imUser          IMUser    @relation(fields: [imUserId], references: [id], onDelete: Cascade)
  bridgeMessages  IMBridgeMessage[]

  @@unique([imUserId, platform])
  @@index([platform, status])
  @@map("im_bindings")
}

// ==============================================================================
// v0.3.0 — 消息桥接记录
// ==============================================================================

model IMBridgeMessage {
  id                String    @id @default(cuid()) @db.VarChar(30)
  bindingId         String    @db.VarChar(30)
  direction         String    @db.VarChar(10)

  imMessageId       String?   @db.VarChar(30)
  imConversationId  String?   @db.VarChar(30)

  externalMessageId String?   @db.VarChar(200)

  status            String    @default("sent") @db.VarChar(20)
  errorMessage      String?   @db.Text

  createdAt         DateTime  @default(now()) @db.DateTime(3)

  binding           IMBinding @relation(fields: [bindingId], references: [id], onDelete: Cascade)

  @@index([bindingId])
  @@index([imMessageId])
  @@map("im_bridge_messages")
}

// ==============================================================================
// v1.6.0 — Context Cache (Prisma-first, replaces backend context_data)
// ==============================================================================

model ContextCache {
  id            String    @id @default(cuid()) @db.VarChar(30)
  userId        String    @db.VarChar(50)
  rawLink       String    @db.Text
  rawLinkHash   String    @unique @db.VarChar(64)    // SHA-256 hex = 64 chars
  contentUri    String?   @db.VarChar(500)
  hqccContent   String    @default("") @db.LongText  // Up to ~4GB (100MB gate at service layer)
  intrContent   String?   @db.LongText               // Up to ~4GB
  visibility    String    @default("private") @db.VarChar(20)
  meta          String    @default("{}") @db.Text
  tags          String    @default("[]") @db.Text   // JSON: string[] — search tags
  sizeBytes     Int       @default(0)
  expiresAt     DateTime? @db.DateTime(3)
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  updatedAt     DateTime  @updatedAt @db.DateTime(3)

  @@index([userId])
  @@index([userId, visibility])
  @@index([expiresAt])
  @@map("im_context_cache")
}

// ==============================================================================
// v1.6.0 — 文件上传记录 (IM File Transfer)
// ==============================================================================

model IMFileUpload {
  id            String    @id @default(cuid()) @db.VarChar(30)
  imUserId      String    @db.VarChar(30)
  uploadId      String    @unique @db.VarChar(200)
  fileName      String    @db.VarChar(500)
  fileSize      Int
  mimeType      String    @db.VarChar(100)
  sha256        String?   @db.VarChar(64)
  s3Key         String?   @db.VarChar(500)
  cdnUrl        String?   @db.VarChar(500)
  status        String    @default("pending") @db.VarChar(20)
  expiresAt     DateTime? @db.DateTime(3)
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  updatedAt     DateTime  @updatedAt @db.DateTime(3)

  imUser        IMUser    @relation(fields: [imUserId], references: [id], onDelete: Cascade)

  @@index([imUserId])
  @@index([status])
  @@map("im_file_uploads")
}

// ==============================================================================
// v1.7.0 — Sync Events (offline-first SDK)
// ==============================================================================

model IMSyncEvent {
  id              Int      @id @default(autoincrement())
  type            String   @db.VarChar(50)
  data            String   @default("{}") @db.Text
  conversationId  String?  @db.VarChar(30)
  imUserId        String   @db.VarChar(30)
  createdAt       DateTime @default(now()) @db.DateTime(3)

  @@index([imUserId])
  @@index([conversationId])
  @@map("im_sync_events")
}

// ==============================================================================
// v1.7.2 — Task Orchestration (Cloud Task Store + Scheduler)
// ==============================================================================

model IMTask {
  id            String    @id @default(cuid()) @db.VarChar(30)

  // Task content
  title         String    @db.VarChar(255)
  description   String?   @db.Text
  capability    String?   @db.VarChar(100)
  input         String    @default("{}") @db.Text
  contextUri    String?   @db.VarChar(500)

  // Participants
  creatorId     String    @db.VarChar(36)
  assigneeId    String?   @db.VarChar(36)
  scope         String    @default("global") @db.VarChar(100)
  conversationId String?  @db.VarChar(36)

  // State machine
  status        String    @default("pending") @db.VarChar(20)
  progress      Float?    @db.Double
  statusMessage String?   @db.VarChar(500)

  // Scheduling
  scheduleType  String?   @db.VarChar(20)
  scheduleAt    DateTime? @db.DateTime(3)
  scheduleCron  String?   @db.VarChar(100)
  intervalMs    Int?
  nextRunAt     DateTime? @db.DateTime(3)
  lastRunAt     DateTime? @db.DateTime(3)
  runCount      Int       @default(0)
  maxRuns       Int?

  // Result
  result        String?   @db.Text
  resultUri     String?   @db.VarChar(500)
  error         String?   @db.Text

  // Economy
  budget        Float?    @db.Double
  cost          Float     @default(0) @db.Double

  // Timeout / Retry
  timeoutMs     Int       @default(300000)
  deadline      DateTime? @db.DateTime(3)
  completedAt   DateTime? @db.DateTime(3)
  maxRetries    Int       @default(0)
  retryDelayMs  Int       @default(60000)
  retryCount    Int       @default(0)

  // Metadata
  metadata      String    @default("{}") @db.Text
  createdAt     DateTime  @default(now()) @db.DateTime(3)
  updatedAt     DateTime  @updatedAt @db.DateTime(3)

  logs          IMTaskLog[]

  @@index([status])
  @@index([assigneeId, status])
  @@index([capability, status])
  @@index([scheduleType, nextRunAt, status])
  @@index([creatorId])
  @@index([creatorId, scope, status])
  @@index([conversationId])
  @@index([completedAt])
  @@map("im_tasks")
}

model IMTaskLog {
  id            String    @id @default(cuid()) @db.VarChar(30)
  taskId        String    @db.VarChar(30)
  actorId       String?   @db.VarChar(36)
  action        String    @db.VarChar(50)
  message       String?   @db.Text
  metadata      String    @default("{}") @db.Text
  createdAt     DateTime  @default(now()) @db.DateTime(3)

  task          IMTask    @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId, createdAt])
  @@map("im_task_logs")
}

// ==============================================================================
// v1.7.2 — Compaction Summaries (Working Memory)
// ==============================================================================

model IMCompactionSummary {
  id                String    @id @default(cuid()) @db.VarChar(30)
  conversationId    String    @db.VarChar(30)
  summary           String    @default("") @db.LongText
  messageRangeStart String?   @db.VarChar(30)
  messageRangeEnd   String?   @db.VarChar(30)
  tokenCount        Int       @default(0)
  createdAt         DateTime  @default(now()) @db.DateTime(3)

  @@index([conversationId])
  @@map("im_compaction_summaries")
}

// ==============================================================================
// v1.7.2 — Memory Files (Episodic Memory)
// ==============================================================================

model IMMemoryFile {
  id          String    @id @default(cuid()) @db.VarChar(30)
  ownerId     String    @db.VarChar(30)
  ownerType   String    @default("agent") @db.VarChar(10)
  scope       String    @default("global") @db.VarChar(50)
  path        String    @default("MEMORY.md") @db.VarChar(255)
  content     String    @default("") @db.MediumText
  version     Int       @default(1)
  createdAt   DateTime  @default(now()) @db.DateTime(3)
  updatedAt   DateTime  @updatedAt @db.DateTime(3)

  memoryType          String?   @db.VarChar(20)
  description         String?   @db.VarChar(500)
  lastConsolidatedAt  DateTime? @db.DateTime(3)
  stale               Boolean   @default(false)

  @@unique([ownerId, scope, path])
  @@index([ownerId, ownerType])
  @@map("im_memory_files")
}

// ==============================================================================
// v1.7.2 — Gene 独立表 (Fix: added to MySQL schema, was missing)
// ==============================================================================

model IMGene {
  id               String    @id @db.VarChar(100)
  category         String    @db.VarChar(20)
  title            String    @default("") @db.VarChar(200)
  description      String    @default("") @db.Text
  strategySteps    String    @db.Text
  preconditions    String    @db.Text
  constraints      String    @db.Text
  visibility       String    @default("private") @db.VarChar(20)
  ownerAgentId     String    @db.VarChar(30)
  parentId         String?   @db.VarChar(100)
  generation       Int       @default(1)
  forkCount        Int       @default(0)
  successCount     Int       @default(0)
  failureCount     Int       @default(0)
  qualityScore     Float     @default(0.01) @db.Double
  lastUsedAt       DateTime? @db.DateTime(3)
  createdAt        DateTime  @default(now()) @db.DateTime(3)
  updatedAt        DateTime  @updatedAt @db.DateTime(3)

  // Circuit Breaker (Fix: DB-persisted, multi-pod safe)
  breakerState     String    @default("closed") @db.VarChar(20)
  breakerFailCount Int       @default(0)
  breakerStateAt   DateTime? @db.DateTime(3)

  scope            String    @default("global") @db.VarChar(60)
  encrypted        Boolean   @default(false)
  encryptionKeyId  String?   @db.VarChar(30)

  signalLinks      IMGeneSignal[]

  @@index([ownerAgentId])
  @@index([category])
  @@index([visibility])
  @@index([parentId])
  @@index([scope, visibility])
  @@map("im_genes")
}

model IMGeneSignal {
  geneId      String  @db.VarChar(100)
  signalId    String  @db.VarChar(200)
  affinity    Float   @default(1.0) @db.Double
  signalTags  String? @db.Text  // v0.3.0: JSON-encoded SignalTag[]

  gene        IMGene  @relation(fields: [geneId], references: [id], onDelete: Cascade)

  @@id([geneId, signalId])
  @@index([signalId])
  @@map("im_gene_signals")
}

// ==============================================================================
// v1.7.2 — Evolution Edge (Skill Evolution Memory Graph)
// ==============================================================================

model IMEvolutionEdge {
  id              String    @id @default(cuid()) @db.VarChar(30)
  ownerAgentId    String    @db.VarChar(30)
  signalKey       String    @db.VarChar(500)
  geneId          String    @db.VarChar(100)
  successCount    Int       @default(0)
  failureCount    Int       @default(0)
  lastScore       Float?    @db.Double
  lastUsedAt      DateTime? @db.DateTime(3)
  createdAt       DateTime  @default(now()) @db.DateTime(3)
  updatedAt       DateTime  @updatedAt @db.DateTime(3)

  // v0.3.0: Signal architecture fields (@map for snake_case MySQL columns)
  signalType      String?   @db.VarChar(128)
  bimodalityIndex Float     @default(0) @db.Float
  taskSuccessRate Float?    @db.Float
  coverageLevel   Int       @default(0) @db.TinyInt
  mode            String    @default("standard") @db.VarChar(20)
  scope           String    @default("global") @db.VarChar(60)

  @@unique([ownerAgentId, signalKey, geneId, mode, scope])
  @@index([ownerAgentId])
  @@index([geneId])
  @@index([signalType])
  @@index([mode])
  @@map("im_evolution_edges")
}

// ==============================================================================
// v1.7.2 — Evolution Capsule (Gene execution record)
// ==============================================================================

model IMEvolutionCapsule {
  id              String    @id @default(cuid()) @db.VarChar(30)
  ownerAgentId    String    @db.VarChar(30)
  geneId          String    @db.VarChar(100)
  signalKey       String    @db.VarChar(500)
  triggerSignals  String    @default("[]") @db.Text
  outcome         String    @default("pending") @db.VarChar(20)
  score           Float?    @db.Double
  summary         String    @default("") @db.Text
  costCredits     Float     @default(0) @db.Double
  metadata        String    @default("{}") @db.Text
  provider        String?   @db.VarChar(50)        // Provider tag for provider-scoped freeze
  mode            String    @default("standard") @db.VarChar(20)
  scope           String    @default("global") @db.VarChar(60)
  encrypted       Boolean   @default(false)
  createdAt       DateTime  @default(now()) @db.DateTime(3)

  reflection          String?   @db.Text
  transitionReason    String?   @db.VarChar(100) // 'gene_applied' | 'fallback_relaxed' | 'baseline'
  contextSnapshot     String?   @db.Text         // JSON: capsule execution context

  @@index([ownerAgentId])
  @@index([geneId])
  @@index([ownerAgentId, outcome])
  @@index([provider])
  @@index([mode])
  @@index([scope])
  @@map("im_evolution_capsules")
}

