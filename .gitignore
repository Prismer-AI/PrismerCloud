# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# prisma generated clients
prisma/generated/

# prisma dev databases
prisma/data/
prisma/dev.db
prisma/prisma/

# sdk build artifacts
sdk/golang/prismer
sdk/rust/target/
sdk/rust/.next/
ref/

# screenshots & captures
*.png
*.jpeg
*.jpg
!docs/*.png

# local tool state
.playwright-mcp/
.ralph/
.ralphrc.env.local
.mcp.json
