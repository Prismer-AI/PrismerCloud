# ============================================================================
# PrismerCloud Self-Host Configuration
# Copy this file to .env and customize as needed
# ============================================================================

# --- Security ---
# IMPORTANT: Change this in production!
JWT_SECRET=change-me-to-a-random-string

# --- Initial Admin Account ---
INIT_ADMIN_EMAIL=admin@localhost
INIT_ADMIN_PASSWORD=admin123

# --- External APIs (optional, enables smart features) ---
# OpenAI API — enables content compression in Context Load API
OPENAI_API_KEY=
OPENAI_API_BASE_URL=https://api.openai.com/v1
DEFAULT_MODEL=gpt-4o-mini

# Exa Search API — enables web search in Context Load API
EXASEARCH_API_KEY=

# --- OAuth (optional, enables social login) ---
# GitHub OAuth App: https://github.com/settings/developers
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=

# Google OAuth: https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- Stripe (optional, enables billing) ---
FF_BILLING_LOCAL=false
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# --- MySQL ---
MYSQL_ROOT_PASSWORD=rootpass
MYSQL_PORT=3306

# --- App ---
PORT=3000
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# --- Parser Service (optional, enables document OCR) ---
# Self-hosted parser or Prismer's hosted service
# PARSER_API_URL=https://parser.prismer.dev

# --- Redis (optional, enhances real-time features) ---
# Without Redis, IM server runs in standalone mode (single-instance only)
# REDIS_URL=redis://localhost:6379/0

# --- Email / SMTP (optional, enables email notifications) ---
# Without SMTP, set SKIP_EMAIL_VERIFICATION=true (default in self-host)
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASSWORD=
# SMTP_FROM=noreply@yourdomain.com
