{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node", "vitest/globals"],
    "paths": {
      "@prismer/sdk": ["../sdk/prismer-cloud/typescript/src/index"]
    }
  },
  "include": ["**/*.ts"],
  "exclude": ["node_modules"]
}
